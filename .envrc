if has guix; then
    watch_file channels.lock.scm manifest.scm
    eval "$(guix time-machine -C channels.lock.scm -- shell -m manifest.scm --search-paths)"
fi

CURRENT="$(pwd -P)"

export GUILE_LOAD_PATH=$CURRENT/modules:${GUILE_LOAD_PATH}
export GUIX_PACKAGE_PATH=$CURRENT/modules:${GUIX_PACKAGE_PATH}
